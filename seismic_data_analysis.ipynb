   "source": [
    "library(dplyr)\n",
    "library(stringr)\n",
    "\n",
    "sites <- c(\"HATAY\", \"MUGLA\", \"IZMIR\", \"MALATYA\", \"MANISA\", \"ÇANAKKALE\")\n",
    "\n",
    "clean_df <- df %>%\n",
    "  filter(Type == \"MW\", Magnitude >= 4, Depth <= 75) %>%\n",
    "  mutate(\n",
    "    Site = str_extract(Location, \"(?<=\\\\().+?(?=\\\\))\"),  \n",
    "    Site = toupper(Site),                             \n",
    "    SiteCat = case_when(\n",
    "      Site %in% sites ~ Site,                    \n",
    "      TRUE ~ \"Other\"                                        \n",
    "    )\n",
    "  )\n",
    "\n",
    "clean_df %>% count(SiteCat)"
   ]
  },
