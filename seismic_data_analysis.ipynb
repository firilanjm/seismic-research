    "# haversine function\n",
    "haversine <- function(lat1, lon1, lat2, lon2) {\n",
    "  R <- 6371  # Earth radius in km\n",
    "  \n",
    "  lat1 <- lat1 * pi/180\n",
    "  lon1 <- lon1 * pi/180\n",
    "  lat2 <- lat2 * pi/180\n",
    "  lon2 <- lon2 * pi/180\n",
    "  \n",
    "  dlat <- lat2 - lat1\n",
    "  dlon <- lon2 - lon1\n",
    "  \n",
    "  a <- sin(dlat/2)^2 + cos(lat1) * cos(lat2) * sin(dlon/2)^2\n",
    "  c <- 2 * atan2(sqrt(a), sqrt(1 - a))\n",
    "  \n",
    "  R * c\n",
    "}"
   ]
  },
